# ─────────────────────────────────────────────────────────────────────────────
# ARBIHOST — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API key.
# cp .env.example .env
#
# IMPORTANT: Never commit your .env file. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# RENTCAST API KEY (required)
# Get your free key at: https://app.rentcast.io/app/api-keys
# Free tier: 50 API requests/month (enough for daily use)
# Paid plans start at $29/month for unlimited requests
RENTCAST_API_KEY=your_rentcast_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Default market multiplier for STR revenue projection
# Miami average is 2.1x (Airbnb revenue / long-term rent ratio)
# Adjust based on your target market. Range: 1.5 (low) to 3.0 (tourist hotspot)
# ARBIHOST_STR_MULTIPLIER=2.1

# Default occupancy rate assumption (%)
# ARBIHOST_DEFAULT_OCCUPANCY=75
